      "source": [
        "# Partie A : Génération des données\n",
        "\n",
        "seed(71)                   # graine aléatoire\n",
        "n = 1000                   # points sur l'axe horizontal\n",
        "\n",
        "x = rand(n) * 10           # 1000 valeurs uniformes dans l'intervalle [0,10)\n",
        "y = zeros(n)               # un vecteurs contenant 1000 zéros\n",
        "points = array([x,y])      # matrice (2x1000) qui fusionnent x et y\n",
        "\n",
        "# matrice de rotation\n",
        "teta = pi/6                                    # 30 dégrés\n",
        "R_teta = array([[cos(teta), -sin(teta)],       # matrice de rotation (2x2)\n",
        "                [sin(teta), cos(teta)]])\n",
        "\n",
        "# rotation des points\n",
        "points_rotation = dot(R_teta, points)     # (2x2)x(2x1000): on trouve une matrice (2x1000)\n",
        "\n",
        "# bruit Gaussien 2D\n",
        "bruit = randn(2,n) * 1                   # écart type de 1 : les données sont moins éparpillées. On aurait pu prendre 0.5 aussi pour plus de précision.\n",
        "\n",
        "X = (points_rotation + bruit).T          # jeu de données final : une addition de matrice (2x1000) nous donne une matrice (2x1000)\n",
        "                                         # la transposée parce qu'on veut une matrice (1000x2) : 1000 données  et deux variables\n",
        "\n",
        "\n",
        "# Partie B : Mahalanobis et PCA\n",
        "\n",
        "# moyenne et la matrice de covariance\n",
        "mu = mean(X, axis=0)\n",
        "\n",
        "# soit \"ecart\", la différence entre nos données et la moyenne\n",
        "ecart = (X-mu)\n",
        "ecart_t = transpose(ecart)\n",
        "\n",
        "sigma = dot(ecart_t, ecart) / (n-1)\n",
        "sigma_inv = inv(sigma)\n",
        "\n",
        "# distance de Mahalanobis\n",
        "matrice_dist_carre = dot(dot(ecart, sigma_inv), ecart_t)   # Matrice (1000x1000)\n",
        "D = sqrt(diag(matrice_dist_carre))                         # Vecteur (1000,)\n",
        "\n",
        "# PCA\n",
        "u, s, v = svd(ecart_t)\n",
        "\n",
        "# vecteurs propres\n",
        "phi_1 = u[:, 0]\n",
        "phi_2 = u[:, 1]\n",
        "\n",
        "# calcul des valeurs propres à partir des valeurs singulières\n",
        "lambda_1 = (s[0] * s[0]) / (n - 1)\n",
        "lambda_2 = (s[1] * s[1]) / (n - 1)\n",
        "\n",
        "\n",
        "\n",
        "# Partie C : Visualisation\n",
        "\n",
        "# fenêtre de figure\n",
        "figure()\n",
        "\n",
        "# nuage de points avec X[:,0] en abscisse et X[:,1] en ordonnée\n",
        "scatter(X[:,0], X[:,1], c=D, s=9)\n",
        "\n",
        "# calcul des vecteurs de la PCA\n",
        "V1 = sqrt(lambda_1) * phi_1\n",
        "V2 = sqrt(lambda_2) * phi_2\n",
        "\n",
        "# coordonnées du centroïde\n",
        "mu_x = mu[0]\n",
        "mu_y = mu[1]\n",
        "\n",
        "# tracé des composantes principales\n",
        "quiver(mu_x, mu_y, V1[0], V1[1], color='k', scale=1, linewidth=4, scale_units='xy', angles='xy')\n",
        "quiver(mu_x, mu_y, V2[0], V2[1], color='k', scale=1, linewidth=4, scale_units='xy', angles='xy')\n",
        "\n",
        "title('Données et composantes principales')\n",
        "axis('equal')                                 # même échelle\n",
        "\n",
        "show()\n",
        "\n"
      ],

      "source": [
        "# nettoyage des données\n",
        "matrice_D = distances.values\n",
        "print(matrice_D.shape)                                    # vérifier si on a une matrice carré\n",
        "\n",
        "# conversion en format condensé\n",
        "D_condense = squareform(matrice_D)\n",
        "\n",
        "# regroupement hiérarchique\n",
        "Z = linkage(D_condense, method='single')                  # liaison simple, alors méthode single\n",
        "\n",
        "# dendrogramme\n",
        "plt.figure(figsize=(10, 6))\n",
        "dendrogram(Z)\n",
        "\n",
        "plt.title('Dendrogramme du regroupement hiérarchique (liaison Simple)')\n",
        "plt.xlabel('Index des points')\n",
        "plt.ylabel('Distance (Seuil)')\n",
        "plt.show()\n",
        "\n",
        "# couper le dendrogramme\n",
        "\n",
        "# MDS\n",
        "mds_algo = MDS(n_components=2, dissimilarity='precomputed', random_state=42)\n",
        "Y_mds_q3 = mds_algo.fit_transform(matrice_D)\n",
        "\n",
        "# les 4 premiers tau sont les 4 premières fusions dans Z\n",
        "niveaux_tau = Z[:4, 2]\n",
        "\n",
        "fig, axes = plt.subplots(2, 2, figsize=(14, 12))           # pour mieux afficher les 4 graphiques\n",
        "axes = axes.flatten()                                      # aplatissement de l'axe\n",
        "\n",
        "for idx, tau in enumerate(niveaux_tau):\n",
        "    groupes = fcluster(Z, t=tau, criterion='distance')\n",
        "\n",
        "    ax = axes[idx]                                         # idx varie entre 0 et 3\n",
        "\n",
        "    ax.scatter(Y_mds_q3[:, 0], Y_mds_q3[:, 1],\n",
        "                c=groupes, cmap='tab10', s=150, edgecolors='k')\n",
        "\n",
        "    for i in range(matrice_D.shape[0]):\n",
        "        ax.annotate(str(i), (Y_mds_q3[i, 0] + 1, Y_mds_q3[i, 1] + 1),\n",
        "                     fontsize=11, fontweight='bold')\n",
        "\n",
        "    ax.set_title(f'Niveau {idx+1} — τ = {tau:.4f}')\n",
        "    ax.set_xlabel('Dimension 1')\n",
        "    ax.set_ylabel('Dimension 2')\n",
        "    ax.grid(True, linestyle='--', alpha=0.6)\n",
        "\n",
        "plt.suptitle('MDS 2D — 4 premiers niveaux du dendrogramme')       # titre global\n",
        "plt.tight_layout()                                                # ajustement de l'espace\n",
        "plt.show()\n",
        "\n",
        "\n"

        "def isomap(X, epsilon, d):\n",
        "\n",
        "  n = X.shape[0]\n",
        "\n",
        "  # matrice des distances euclidiennes\n",
        "  D = cdist(X, X)\n",
        "\n",
        "  seuil = epsilon(D)                       # appliquer la fonction epsilon à D pour avoir le seuil\n",
        "\n",
        "  # contruction du graphe de voisinage\n",
        "  D_geo = D.copy()                         # Distance géodésique\n",
        "  D_geo[D > seuil] = np.inf                # supprimer les distances supérieures au seuil\n",
        "  np.fill_diagonal(D_geo, 0)               # forcer la diagonale à 0\n",
        "\n",
        "\n",
        "  # distances géodésiques (Plus courts chemins)\n",
        "  for k in range(n):\n",
        "          D_geo = np.minimum(D_geo, D_geo[:, [k]] + D_geo[[k], :])\n",
        "\n",
        "  #valeur_max = D_geo[~np.isinf(D_geo)].max()\n",
        "  #D_geo = np.where(np.isinf(D_geo), 2 * valeur_max, D_geo)\n",
        "\n",
        "  # MDS\n",
        "  D_carre = D_geo ** 2                     # matrice des distances géodésiques au carré\n",
        "  H = np.eye(n) - np.ones((n, n)) / n      # matrice de centrage H\n",
        "  B = -0.5 * H @ D_carre @ H               # matrice de Gram\n",
        "\n",
        "  # valeurs et vecteurs propres de la matrice de Gram\n",
        "  valeurs_propres, vecteurs_propres = np.linalg.eigh(B)\n",
        "\n",
        "  # tri en ordre décroissant\n",
        "  indices = np.argsort(valeurs_propres)[::-1]\n",
        "  valeurs_propres = valeurs_propres[indices]\n",
        "  vecteurs_propres = vecteurs_propres[:, indices]\n",
        "\n",
        "  valeurs_propres[:d] = np.maximum(valeurs_propres[:d], 0)\n",
        "\n",
        "  Y = vecteurs_propres[:, :d] * np.sqrt(valeurs_propres[:d])\n",
        "\n",
        "  return Y\n",
        "\n",
        "\n"
      ],
